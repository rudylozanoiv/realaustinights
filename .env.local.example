# Copy to .env.local and fill in values locally. Do NOT commit .env.local.

# Supabase project URL (https://<project-id>.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key. Browser-safe. Do NOT use service-role / secret keys here.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# reCAPTCHA v3 site key (public, safe for client). Get from https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Plausible Analytics domain. Leave blank to disable the script tag.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
